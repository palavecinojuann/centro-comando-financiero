rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ⚠️ REGLAS TEMPORALES DE DESARROLLO
    // TODO: Restaurar autenticación obligatoria antes de ir a producción definitiva
    // Las reglas originales están en DRAFT_firestore.rules
    
    // Acceso abierto temporal para el hogar del búnker durante la fase de carga de datos
    match /hogares/{hogarId}/{document=**} {
      allow read, write: if true;
    }
    
    // Perfiles de usuario
    match /usuarios/{userId} {
      allow read, write: if true;
    }
  }
}
