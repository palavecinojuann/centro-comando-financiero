rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNCIONES DE SEGURIDAD ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Verifica si el usuario pertenece a la lista de miembros de un hogar
    function esMiembroDelHogar(idHogar) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/hogares/$(idHogar)) &&
             request.auth.uid in get(/databases/$(database)/documents/hogares/$(idHogar)).data.miembros;
    }

    // --- REGLAS POR COLECCIÓN ---

    // Denegar acceso por defecto
    match /{document=**} {
      allow read, write: if false;
    }

    // Perfiles de usuario
    match /usuarios/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Colección de Hogares (Búnkers)
    match /hogares/{idHogar} {
      // Solo miembros pueden leer la configuración del hogar
      allow read: if esMiembroDelHogar(idHogar);
      
      // Permitir creación inicial si el usuario se incluye como miembro (simplificado)
      allow create: if isAuthenticated() && request.resource.data.miembros.hasAll([request.auth.uid]);
      
      // Subcolecciones tácticas (gastos, compromisos, configuraciones)
      match /{coleccion}/{documento} {
        allow read, write: if esMiembroDelHogar(idHogar);
      }
    }
    
    // Colección global de auditoría (opcional)
    match /logs/{logId} {
      allow create: if isAuthenticated();
    }
  }
}
